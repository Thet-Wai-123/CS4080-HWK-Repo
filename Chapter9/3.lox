var i = 0;
while (i < 10) {
	print i;
	if (i == 3) {
        	print "break is called and WHILE loop will end";
        	break;
    	}
    i = i + 1;
}

i = 0;
for (var i = 0; i < 10; i = i + 1) {
    print i;
    if (i == 3) {
        print "break is called and FOR loop will end";
        break;
    }
}

